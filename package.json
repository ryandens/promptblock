{
  "name": "promptblock",
  "version": "0.1.0",
  "private": true,
  "description": "A GitHub App that scans issues and comments for prompt injection — including content hidden in HTML comments.",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "start": "probot run ./lib/index.js",
    "dev": "tsc --watch & probot run ./lib/index.js",
    "test": "tsc && node --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@stackone/defender": "^0.7.1",
    "probot": "^14.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@11.8.0",
  "license": "Apache-2.0"
}
