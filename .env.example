# Copy to .env and fill in. The app reads these at runtime.

APP_ID=
PRIVATE_KEY_PATH=./private-key.pem
WEBHOOK_SECRET=

# For local development: forward GitHub webhooks to localhost via smee.io.
# Run `pnpm smee:new` to provision a channel, then paste the URL here and set
# the GitHub App's webhook URL to match. With this set, `pnpm start` connects
# the smee client automatically.
# WEBHOOK_PROXY_URL=https://smee.io/your-channel
