{
  "name": "promptblock",
  "version": "0.1.0",
  "private": true,
  "description": "A Probot GitHub App that scans issues and comments for prompt injection — including content hidden in HTML comments — using @stackone/defender.",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "start": "probot run ./lib/index.js",
    "dev": "tsc --watch & probot run ./lib/index.js",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stackone/defender": "^0.7.1",
    "probot": "^14.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
